@page "/transactions"
@using FinanceAPP.Models
@using System.Globalization
@inject FinanceAPP.Services.CategoryService categoryService
@inject FinanceAPP.Services.TransactionService transactionService

<h3>Adicionar Transação</h3>

@if (isLoading)
{
    <p>Carregando...</p>
}
else
{
<div>
	<label>Category:</label>
		<InputSelect @bind-Value="newTransaction.CategoryId">
			<option value="@Guid.Empty.ToString()">-- Selecionar Categoria --</option>
			@foreach (var c in categoryService.Categories)
			{
				<option value="@c.Id.ToString()">@c.Name</option>
			}
		</InputSelect>
</div>

<div>
	<label>Descrição:</label>
	<input @bind="newTransaction.Description" />
</div>

<div>
	<label>Valor:</label>
	<input type="number" @bind="newTransaction.Amount" />
</div>

<div>
	<label>Tipo de Transação:</label>
	<InputSelect @bind-Value="newTransaction.Type">
		@foreach (var type in Enum.GetValues<Transaction.TransactionType>())
		{
			<option value="@type.ToString()">@type</option>
		}
	</InputSelect>
</div>

<div>
	<label>Data (dd/MM/yyyy):</label>
	<input type="date" @bind="operationDateInput" />
</div>

<button @onclick="AddTransaction">
	@(editingTransaction == null ? "Adicionar" : "Salvar")
</button>
}
<hr />

<h3>Todas as Transações</h3>

@if (transactionService.Transactions.Count == 0)
{
	<p>Transações não encontradas.</p>
}
else
{
	<ul>
		@foreach (var t in transactionService.Transactions)
		{
			<li>@t.OperationDate.ToString("dd/MM/yy", CultureInfo.InvariantCulture) - @t.Type - @categoryService.GetCategoryName(t.CategoryId) - @t.Description - R$ @t.Amount</li>
			<button @onclick="(() => RemoveTransaction(t))">Remover</button>
			<button @onclick="(() => StartEdit(t))">Editar</button>
		}
	</ul>
}

@code {
	private Transaction? editingTransaction = null;
	private Transaction newTransaction = new();
	private DateOnly operationDateInput = DateOnly.FromDateTime(DateTime.Now);
	private bool isLoading = true;  // Add this


	protected override async Task OnInitializedAsync()
	{
		await categoryService.LoadAsync();
		await transactionService.LoadAsync();
		isLoading = false;  // Add this
	}

	private async Task AddTransaction()
	{
		if (editingTransaction == null)
		{
			// Adding new transaction
			newTransaction.OperationDate = operationDateInput;
			await transactionService.AddAsync(newTransaction);
		}
		else
		{
			// Editing existing transaction
			editingTransaction.CategoryId = newTransaction.CategoryId;
			editingTransaction.Description = newTransaction.Description;
			editingTransaction.Type = newTransaction.Type;
			editingTransaction.Amount = newTransaction.Amount;
			editingTransaction.OperationDate = operationDateInput;
			await transactionService.UpdateAsync(editingTransaction);
			editingTransaction = null;  // Done editing
		}

		// Reset form
		newTransaction = new();
		operationDateInput = DateOnly.FromDateTime(DateTime.Now);
	}

	private async Task RemoveTransaction(Transaction t)
	{
		await transactionService.DeleteAsync(t);

	}

	private void StartEdit(Transaction t)
	{
		editingTransaction = t;  // Mark this transaction as being edited

		// Populate the form with this transaction's data
		newTransaction.CategoryId = t.CategoryId;
		newTransaction.Description = t.Description;
		newTransaction.Type = t.Type;
		newTransaction.Amount = t.Amount;
		operationDateInput = t.OperationDate;
	}
}