@page "/categories"
@using FinanceAPP.Models
@using System.Globalization
@inject FinanceAPP.Services.CategoryService categoryService

<h3>Categorias de Transação</h3>

<div>
	<label>Categoria:</label>
	<input @bind="newCategory.Name" />
</div>
<div>
	<label>Descrição:</label>
	<input @bind="newCategory.Description" />
</div>

<button @onclick="AddCategory">
	@(editingCategory == null ? "Adicionar" : "Salvar")
</button>

<h3>Todas as Categorias</h3>
@if (categoryService.Categories.Count == 0)
{
	<p>Nenhuma categoria encontrada.</p>
}
else
{
	<ul>
		@foreach (var c in categoryService.Categories)
		{
			<li>@c.Name - @c.Description</li>
			<button @onclick="(() => RemoveCategory(c))">Remover</button>
			<button @onclick="(() => StartEdit(c))">Editar</button>
		}
	</ul>
}

@code {
	private Category? editingCategory = null;
	private Category newCategory = new();

	protected override async Task OnInitializedAsync()
	{
		await categoryService.LoadAsync();
	}

	private async Task AddCategory()
	{
		if (editingCategory == null)
		{
			// Adding new transaction
			await categoryService.AddAsync(newCategory);
		}
		else
		{
			// Editing existing transaction
			editingCategory.Name = newCategory.Name;
			editingCategory.Description = newCategory.Description;
			await categoryService.UpdateAsync(editingCategory);
			editingCategory = null;  // Done editing
		}

		// Reset form
		newCategory = new();
	}

	private async Task RemoveCategory(Category c)
	{
		await categoryService.DeleteAsync(c);
	}

	private void StartEdit(Category c)
	{
		editingCategory = c;  // Mark this transaction as being edited

		// Populate the form with this transaction's data
		newCategory.Name = c.Name;
		newCategory.Description = c.Description;

	}
}
