@page "/Import_export"
@using FinanceAPP.Models
@inject Blazored.LocalStorage.ILocalStorageService localStorage
@inject IJSRuntime JSRuntime

<h3>Import / Export</h3>

<h4>Export</h4>
<button @onclick="ExportData">Export Data</button>
@if (!string.IsNullOrEmpty(exportMessage))
{
    <p>@exportMessage</p>
}

<hr />

<h4>Import</h4>
<InputFile OnChange="ImportData" accept=".json" />
@if (!string.IsNullOrEmpty(importMessage))
{
    <p>@importMessage</p>
}

@code {
    private List<Transaction> transactions = new();

    protected override async Task OnInitializedAsync()
    {
        var saved = await localStorage.GetItemAsync<List<Transaction>>("transactions");
        if (saved != null)
        {
            transactions = saved;
        }
    }

    private string exportMessage = "";

    private async Task ExportData()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(transactions, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        var fileName = $"finance-backup-{DateTime.Now:yyyy-MM-dd}.json";

        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var base64 = Convert.ToBase64String(bytes);
        var dataUrl = $"data:application/json;base64,{base64}";

        await JSRuntime.InvokeVoidAsync("downloadFile", fileName, dataUrl);

        exportMessage = $"Exported {transactions.Count} transactions successfully!";
    }

    private string importMessage = "";

    private async Task ImportData(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;

            // Read file content
            using var stream = file.OpenReadStream();
            using var reader = new System.IO.StreamReader(stream);
            var json = await reader.ReadToEndAsync();

            // Deserialize
            var importedTransactions = System.Text.Json.JsonSerializer.Deserialize<List<Transaction>>(json);

            if (importedTransactions != null && importedTransactions.Count > 0)
            {
                transactions = importedTransactions;
                await localStorage.SetItemAsync("transactions", transactions);
                importMessage = $"Successfully imported {transactions.Count} transactions!";
            }
            else
            {
                importMessage = "No transactions found in file.";
            }
        }
        catch (Exception ex)
        {
            importMessage = $"Error importing: {ex.Message}";
        }
    }
}
