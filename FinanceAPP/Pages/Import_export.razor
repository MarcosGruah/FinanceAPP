@page "/Import_export"
@using FinanceAPP.Models
@inject FinanceAPP.Services.DataBackupService backupService
@inject IJSRuntime JSRuntime

<h3>Importar / Exportar</h3>

<h4>Exportar</h4>
<button @onclick="ExportData">Exportar Dados</button>
@if (!string.IsNullOrEmpty(exportMessage))
{
    <p>@exportMessage</p>
}

<hr />

<h4>Importar</h4>
<InputFile OnChange="ImportData" accept=".json" />
@if (!string.IsNullOrEmpty(importMessage))
{
    <p>@importMessage</p>
}

@code {
    private string exportMessage = "";
    private string importMessage = "";

    private async Task ExportData()
    {
        var backup = backupService.CreateBackup();
        var json = System.Text.Json.JsonSerializer.Serialize(backup, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        var fileName = $"finance-backup-{DateTime.Now:yyyy-MM-dd}.json";

        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var base64 = Convert.ToBase64String(bytes);
        var dataUrl = $"data:application/json;base64,{base64}";

        await JSRuntime.InvokeVoidAsync("downloadFile", fileName, dataUrl);

        exportMessage = $"Exportados {backup.Categories.Count} categorias e {backup.Transactions.Count} transações!";
    }

    private async Task ImportData(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            using var stream = file.OpenReadStream();
            using var reader = new System.IO.StreamReader(stream);
            var json = await reader.ReadToEndAsync();

            var backup = System.Text.Json.JsonSerializer.Deserialize<DataBackup>(json);

            if (backup != null)
            {
                await backupService.RestoreBackup(backup);
                importMessage = $"Importação realizada com sucesso! {backup.Categories.Count} categorias e {backup.Transactions.Count} transações.";
            }
            else
            {
                importMessage = "Dados não encontrados no arquivo selecionado.";
            }
        }
        catch (Exception ex)
        {
            importMessage = $"Erro de importação: {ex.Message}";
        }
    }
}