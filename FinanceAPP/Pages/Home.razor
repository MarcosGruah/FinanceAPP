@page "/"
@using FinanceAPP.Models
@using System.Globalization
@inject FinanceAPP.Services.CategoryService categoryService
@inject FinanceAPP.Services.TransactionService transactionService

<PageTitle>Home</PageTitle>

<h2>Resumo</h2>


@if (monthlySummary.Count == 0)
{
	<p>Sem dados para resumir.</p>
}
else
{
	<ul>
		@foreach (var month in monthlySummary)
		{
			var (year, monthNum) = month.Key;
			var (income, expenses) = month.Value;
			var balance = income - expenses;
			var monthName = new DateTime(year, monthNum, 1).ToString("yyyy / MMMM", CultureInfo.InvariantCulture);
			<li>@monthName: Receita = R$ @income.ToString("F2"), Despesas = R$ @expenses.ToString("F2"), Saldo = R$ @balance.ToString("F2")</li>
		}
	</ul>
}

<h2>Resumo por Categoria</h2>

<h3>Receitas por Categoria</h3>
@if (incomeByCategory.Count == 0)
{
	<p>Nenhuma receita registrada.</p>
}
else
{
	@foreach (var month in incomeByCategory.OrderBy(m => m.Key))
	{
		var monthName = new DateTime(month.Key.year, month.Key.month, 1).ToString("MMMM yyyy", CultureInfo.InvariantCulture);
		<h4>@monthName</h4>
		<ul>
			@foreach (var item in month.Value.OrderByDescending(x => x.Value))
			{
				<li>@categoryService.GetCategoryName(item.Key): R$ @item.Value.ToString("N2")</li>
			}
		</ul>
		<p><strong>Subtotal: R$ @month.Value.Values.Sum().ToString("N2")</strong></p>
	}
	<p><strong>Total de Receitas: R$ @incomeByCategory.SelectMany(m => m.Value.Values).Sum().ToString("N2")</strong></p>
}

<h3>Gastos por Categoria</h3>
@if (expensesByCategory.Count == 0)
{
	<p>Nenhum gasto registrado.</p>
}
else
{
	@foreach (var month in expensesByCategory.OrderBy(m => m.Key))
	{
		var monthName = new DateTime(month.Key.year, month.Key.month, 1).ToString("MMMM yyyy", CultureInfo.InvariantCulture);
		<h4>@monthName</h4>
		<ul>
			@foreach (var item in month.Value.OrderByDescending(x => x.Value))
			{
				<li>@categoryService.GetCategoryName(item.Key): R$ @item.Value.ToString("N2")</li>
			}
		</ul>
		<p><strong>Subtotal: R$ @month.Value.Values.Sum().ToString("N2")</strong></p>
	}
	<p><strong>Total de Gastos: R$ @expensesByCategory.SelectMany(m => m.Value.Values).Sum().ToString("N2")</strong></p>
}

<h3>Todas as Transações</h3>
@if (transactionService.Transactions.Count == 0)
{
	<p>Nenhuma transação encontrada.</p>
}
else
{
	<ul>
		@foreach (var t in transactionService.Transactions.OrderBy(x => x.OperationDate))
		{
			<li>  @t.OperationDate.ToString("dd/MM/yy", CultureInfo.InvariantCulture) - @t.Type - @categoryService.GetCategoryName(t.CategoryId) - @t.Description - R$ @t.Amount.ToString("F2")</li>
		}
	</ul>
}
<h3>Todas as Categorias</h3>
@if (categoryService.Categories.Count == 0)
{
	<p>Nenhuma categoria encontrada.</p>
}
else
{
	<ul>
		@foreach (var c in categoryService.Categories)
		{
			<li>  @c.Name - @c.Description</li>
		}
	</ul>
}

@code{
	Dictionary<(int year, int month), (decimal income, decimal expenses)> monthlySummary = new();
	Dictionary<(int year, int month), Dictionary<Guid, decimal>> incomeByCategory = new();
	Dictionary<(int year, int month), Dictionary<Guid, decimal>> expensesByCategory = new();


	protected override async Task OnInitializedAsync()
	{

		await categoryService.LoadAsync();
		await transactionService.LoadAsync();

		BuildMonthSummary();
		BuildCategorySummary();
	}

	private void BuildMonthSummary()
	{
		foreach (Transaction transaction in transactionService.Transactions)
		{
			(int year, int month) key = (transaction.OperationDate.Year, transaction.OperationDate.Month);

			if (!monthlySummary.ContainsKey(key))
			{
				monthlySummary[key] = (0m, 0m);
			}

			(decimal currentIncome, decimal currentExpense) = monthlySummary[key];

			if(transaction.Type == Transaction.TransactionType.Income)
			{
				currentIncome += transaction.Amount;
			}
			else if (transaction.Type == Transaction.TransactionType.Expense)
			{
				currentExpense += transaction.Amount;
			}
			monthlySummary[key] = (currentIncome, currentExpense);
		}
	}

	private void BuildCategorySummary()
	{
		foreach (Transaction transaction in transactionService.Transactions)
		{
			var monthKey = (transaction.OperationDate.Year, transaction.OperationDate.Month);
			var categoryId = transaction.CategoryId;

			if (transaction.Type == Transaction.TransactionType.Income)
			{
				if (!incomeByCategory.ContainsKey(monthKey))
					incomeByCategory[monthKey] = new Dictionary<Guid, decimal>();

				if (!incomeByCategory[monthKey].ContainsKey(categoryId))
					incomeByCategory[monthKey][categoryId] = 0;

				incomeByCategory[monthKey][categoryId] += transaction.Amount;
			}
			else if (transaction.Type == Transaction.TransactionType.Expense)
			{
				if (!expensesByCategory.ContainsKey(monthKey))
					expensesByCategory[monthKey] = new Dictionary<Guid, decimal>();

				if (!expensesByCategory[monthKey].ContainsKey(categoryId))
					expensesByCategory[monthKey][categoryId] = 0;

				expensesByCategory[monthKey][categoryId] += transaction.Amount;
			}
		}
	}
}