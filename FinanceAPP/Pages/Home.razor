@page "/"
@using FinanceAPP.Models
@using System.Globalization
@inject FinanceAPP.Services.CategoryService categoryService
@inject FinanceAPP.Services.TransactionService transactionService
@inject IJSRuntime JSRuntime
<PageTitle>Home</PageTitle>

<div class="container-fluid">
	<h2 class="mb-4">Resumo Financeiro</h2>

	@if (availableMonths.Count > 0)
	{
		<div class="mb-4">
			<label class="form-label fw-bold">Selecione o mês:</label>
			<select class="form-select" style="max-width: 300px;" @onchange="OnMonthChanged">
				@foreach (var month in availableMonths)
				{
					var monthText = FormatMonthName(month.year, month.month);
					var isSelected = selectedMonth.HasValue && selectedMonth.Value == month;
					<option value="@month.year-@month.month" selected="@isSelected">@monthText</option>
				}
			</select>
		</div>
	}

	@if (selectedMonth.HasValue)
	{
		var monthData = monthlySummary.ContainsKey(selectedMonth.Value) ? monthlySummary[selectedMonth.Value] : (0m, 0m);
		var monthName = FormatMonthName(selectedMonth.Value.year, selectedMonth.Value.month);
		var (income, expenses) = monthData;
		var balance = income - expenses;

		<h3 class="mb-3">@monthName</h3>

		<div class="row mb-4">
			<div class="col-md-4 mb-3">
				<div class="card text-white bg-success">
					<div class="card-body">
						<h5 class="card-title">Receitas</h5>
						<p class="card-text fs-4">R$ @income.ToString("N2")</p>
					</div>
				</div>
			</div>
			<div class="col-md-4 mb-3">
				<div class="card text-white bg-danger">
					<div class="card-body">
						<h5 class="card-title">Despesas</h5>
						<p class="card-text fs-4">R$ @expenses.ToString("N2")</p>
					</div>
				</div>
			</div>
			<div class="col-md-4 mb-3">
				<div class="card text-white @(balance >= 0 ? "bg-primary" : "bg-warning")">
					<div class="card-body">
						<h5 class="card-title">Saldo</h5>
						<p class="card-text fs-4">R$ @balance.ToString("N2")</p>
					</div>
				</div>
			</div>
		</div>
	}

	<div class="row">
		<div class="col-lg-6 mb-4">
			<div class="card">
				<div class="card-header bg-success text-white">
					<h4 class="mb-0">Receitas por Categoria</h4>
				</div>
				<div class="card-body">
					@if (!incomeByCategory.Any())
					{
						<p class="text-muted">Nenhuma receita registrada neste mês.</p>
					}
					else
					{
						decimal totalIncome = incomeByCategory.Values.Sum();
						
						@foreach (var item in incomeByCategory.OrderByDescending(x => x.Value))
						{
							decimal itemValue = item.Value;
							decimal percentage = totalIncome > 0 ? (itemValue / totalIncome * 100) : 0;
							string percentageStr = percentage.ToString("F1", CultureInfo.InvariantCulture);
							string widthStr = percentage.ToString("F2", CultureInfo.InvariantCulture);
							
							<div class="mb-3">
								<div class="d-flex justify-content-between align-items-center mb-1">
									<span class="fw-bold" style="cursor: pointer; text-decoration: underline;" @onclick="async () => await FilterByCategory(item.Key)">
										@categoryService.GetCategoryName(item.Key)
									</span>
									<span class="text-muted">
										R$ @itemValue.ToString("N2")
										<small>(@percentageStr%)</small>
									</span>
								</div>
								<div class="progress" style="height: 20px;">
									<div class="progress-bar bg-success"
										 role="progressbar"
										 style="width: @widthStr%"
										 aria-valuenow="@percentage"
										 aria-valuemin="0"
										 aria-valuemax="100">
									</div>
								</div>
							</div>
						}
						
						<div class="mt-4 p-3 bg-light rounded">
							<strong>Total de Receitas: R$ @totalIncome.ToString("N2")</strong>
						</div>
					}
				</div>
			</div>
		</div>

		<div class="col-lg-6 mb-4">
			<div class="card">
				<div class="card-header bg-danger text-white">
					<h4 class="mb-0">Gastos por Categoria</h4>
				</div>
				<div class="card-body">
					@if (!expensesByCategory.Any())
					{
						<p class="text-muted">Nenhum gasto registrado neste mês.</p>
					}
					else
					{
						decimal totalExpenses = expensesByCategory.Values.Sum();
						
						@foreach (var item in expensesByCategory.OrderByDescending(x => x.Value))
						{
							decimal itemValue = item.Value;
							decimal percentage = totalExpenses > 0 ? (itemValue / totalExpenses * 100) : 0;
							string percentageStr = percentage.ToString("F1", CultureInfo.InvariantCulture);
							string widthStr = percentage.ToString("F2", CultureInfo.InvariantCulture);
							
							<div class="mb-3">
								<div class="d-flex justify-content-between align-items-center mb-1">
									<span class="fw-bold" style="cursor: pointer; text-decoration: underline;" @onclick="async () => await FilterByCategory(item.Key)">
										@categoryService.GetCategoryName(item.Key)
									</span>
									<span class="text-muted">
										R$ @itemValue.ToString("N2")
										<small>(@percentageStr%)</small>
									</span>
								</div>
								<div class="progress" style="height: 20px;">
									<div class="progress-bar bg-danger"
										 role="progressbar"
										 style="width: @widthStr%"
										 aria-valuenow="@percentage"
										 aria-valuemin="0"
										 aria-valuemax="100">
									</div>
								</div>
							</div>
						}
						
						<div class="mt-4 p-3 bg-light rounded">
							<strong>Total de Gastos: R$ @totalExpenses.ToString("N2")</strong>
						</div>
					}
				</div>
			</div>
		</div>
	</div>

	<div class="card mb-4" id="transactions-table">
		<div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
			<h4 class="mb-0">
				Todas as Transações do Mês
				@if (selectedCategoryFilter != null)
				{
					<span class="badge bg-warning text-dark ms-2">
						Filtrado: @categoryService.GetCategoryName(selectedCategoryFilter.Value)
					</span>
				}
			</h4>
			@if (selectedCategoryFilter != null)
			{
				<button class="btn btn-sm btn-light" @onclick="ClearCategoryFilter">
					<i class="bi bi-x"></i> Limpar Filtro
				</button>
			}
		</div>
		<div class="card-body">
			@if (selectedMonth.HasValue)
			{
				var monthTransactions = transactionService.Transactions
					.Where(t => t.OperationDate.Year == selectedMonth.Value.year && t.OperationDate.Month == selectedMonth.Value.month)
					.Where(t => selectedCategoryFilter == null || t.CategoryId == selectedCategoryFilter)
					.OrderByDescending(x => x.OperationDate)
					.ToList();

				@if (monthTransactions.Count == 0)
				{
					<p class="text-muted">Nenhuma transação encontrada neste mês.</p>
				}
				else
				{
					<div class="table-responsive">
						<table class="table table-hover">
							<thead class="table-light">
								<tr>
									<th>Data</th>
									<th>Tipo</th>
									<th>Categoria</th>
									<th>Descrição</th>
									<th class="text-end">Valor</th>
									<th class="text-center">Ações</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var t in monthTransactions)
								{
									var rowClass = t.Type == Transaction.TransactionType.Income ? "table-success" : "table-danger";
									<tr class="@rowClass">
										<td>@t.OperationDate.ToString("dd/MM/yyyy")</td>
										<td>
											<span class="badge @(t.Type == Transaction.TransactionType.Income ? "bg-success" : "bg-danger")">
												@t.Type
											</span>
										</td>
										<td>@categoryService.GetCategoryName(t.CategoryId)</td>
										<td>@t.Description</td>
										<td class="text-end fw-bold">R$ @t.Amount.ToString("N2")</td>
										<td class="text-center">
											<a href="/transactions/@t.Id" class="btn btn-sm btn-warning" title="Editar">
												<i class="bi bi-pencil"></i>
											</a>
										</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				}
			}
		</div>
	</div>
</div>

@code {
	Dictionary<(int year, int month), (decimal income, decimal expenses)> monthlySummary = new();
	Dictionary<Guid, decimal> incomeByCategory = new();
	Dictionary<Guid, decimal> expensesByCategory = new();
	private List<(int year, int month)> availableMonths = new();
	private (int year, int month)? selectedMonth = null;
	private Guid? selectedCategoryFilter = null;

	protected override async Task OnInitializedAsync()
	{
		await categoryService.LoadAsync();
		await transactionService.LoadAsync();

		availableMonths = transactionService.Transactions
			.Select(t => (t.OperationDate.Year, t.OperationDate.Month))
			.Distinct()
			.OrderByDescending(m => m)
			.ToList();

		if (availableMonths.Count > 0)
		{
			var now = DateTime.Now;
			selectedMonth = availableMonths.FirstOrDefault(m => m.year == now.Year && m.month == now.Month);
			if (selectedMonth == null || selectedMonth.Value == default)
				selectedMonth = availableMonths.First();
		}

		BuildMonthSummary();
		BuildCategorySummary();
	}

	private void BuildMonthSummary()
	{
		monthlySummary.Clear();

		foreach (Transaction transaction in transactionService.Transactions)
		{
			(int year, int month) key = (transaction.OperationDate.Year, transaction.OperationDate.Month);
			if (!monthlySummary.ContainsKey(key))
			{
				monthlySummary[key] = (0m, 0m);
			}

			var (currentIncome, currentExpense) = monthlySummary[key];
			if (transaction.Type == Transaction.TransactionType.Income)
			{
				currentIncome += transaction.Amount;
			}
			else if (transaction.Type == Transaction.TransactionType.Expense)
			{
				currentExpense += transaction.Amount;
			}
			monthlySummary[key] = (currentIncome, currentExpense);
		}
	}

	private void BuildCategorySummary()
	{
		incomeByCategory.Clear();
		expensesByCategory.Clear();

		if (selectedMonth == null) return;

		var filteredTransactions = transactionService.Transactions
			.Where(t => t.OperationDate.Year == selectedMonth.Value.year
					 && t.OperationDate.Month == selectedMonth.Value.month);

		foreach (Transaction transaction in filteredTransactions)
		{
			var categoryId = transaction.CategoryId;

			if (transaction.Type == Transaction.TransactionType.Income)
			{
				if (!incomeByCategory.ContainsKey(categoryId))
					incomeByCategory[categoryId] = 0;
				incomeByCategory[categoryId] += transaction.Amount;
			}
			else if (transaction.Type == Transaction.TransactionType.Expense)
			{
				if (!expensesByCategory.ContainsKey(categoryId))
					expensesByCategory[categoryId] = 0;
				expensesByCategory[categoryId] += transaction.Amount;
			}
		}
	}

	private string FormatMonthName(int year, int month)
	{
		var date = new DateTime(year, month, 1);
		var monthName = date.ToString("MMMM yyyy", new CultureInfo("pt-BR"));
		return char.ToUpper(monthName[0]) + monthName.Substring(1);
	}

	private void OnMonthChanged(ChangeEventArgs e)
	{
		var parts = e.Value?.ToString()?.Split('-');
		if (parts?.Length == 2 && int.TryParse(parts[0], out int year) && int.TryParse(parts[1], out int month))
		{
			selectedMonth = (year, month);
			selectedCategoryFilter = null;
			BuildCategorySummary();
		}
	}

	private async Task FilterByCategory(Guid categoryId)
	{
		selectedCategoryFilter = categoryId;
		StateHasChanged();
		await Task.Delay(100);
		await JSRuntime.InvokeVoidAsync("scrollToElement", "transactions-table");
	}

	private void ClearCategoryFilter()
	{
		selectedCategoryFilter = null;
	}
}